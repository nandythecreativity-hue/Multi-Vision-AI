{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and credit information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "credits": { "type": "number" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "subscription": { "type": "string", "enum": ["free", "pro", "premium"] }
      },
      "required": ["uid", "email", "credits", "role"]
    },
    "api_keys": {
      "title": "API Keys",
      "description": "User-provided API keys (encrypted)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "provider": { "type": "string", "enum": ["gemini", "openai", "other"] },
        "encryptedKey": { "type": "string" },
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "provider", "encryptedKey", "isActive"]
    },
    "activity_logs": {
      "title": "Activity Logs",
      "description": "Record of user generation actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "text"] },
        "prompt": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "error"] },
        "timestamp": { "type": "number" },
        "keyUsed": { "type": "string", "enum": ["user", "fallback"] },
        "resultUrl": { "type": "string" }
      },
      "required": ["userId", "type", "prompt", "status", "timestamp", "keyUsed"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "users", "description": "User profiles" },
    "api_keys/{keyId}": { "schema": "api_keys", "description": "User API keys" },
    "activity_logs/{logId}": { "schema": "activity_logs", "description": "Generation logs" }
  }
}
