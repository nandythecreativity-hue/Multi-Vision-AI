{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and credit information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Auth"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "imageCredits": {
          "type": "number",
          "description": "Remaining image generation credits"
        },
        "videoCredits": {
          "type": "number",
          "description": "Remaining video generation credits"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role in the application"
        },
        "lastActive": {
          "type": "number",
          "description": "Timestamp of the user's last activity"
        },
        "status": {
          "type": "string",
          "enum": ["online", "offline"],
          "description": "Current online status of the user"
        },
        "imageCount": {
          "type": "number",
          "description": "Total number of images generated by the user"
        },
        "videoCount": {
          "type": "number",
          "description": "Total number of videos generated by the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created"
        }
      },
      "required": ["uid", "email", "imageCredits", "videoCredits", "role"]
    },
    "history": {
      "title": "Generation History",
      "description": "Record of generated videos and images",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID who generated the content"
        },
        "type": {
          "type": "string",
          "enum": ["video", "image"],
          "description": "Type of content generated"
        },
        "url": {
          "type": "string",
          "description": "URL of the generated content"
        },
        "prompt": {
          "type": "string",
          "description": "Prompt used for generation"
        },
        "timestamp": {
          "type": "number",
          "description": "When the content was generated"
        },
        "operation": {
          "type": "object",
          "description": "Metadata about the generation operation"
        }
      },
      "required": ["uid", "type", "url", "prompt", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "history/{historyId}": {
      "schema": "history",
      "description": "Generation history"
    }
  }
}
